services:
  postgres:
    image: postgres:17
    environment:
      POSTGRES_USER: gophkeeper
      POSTGRES_PASSWORD: gophkeeper
      POSTGRES_DB: gophkeeper
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U gophkeeper -d gophkeeper"]
      interval: 5s
      timeout: 5s
      retries: 5
  main:
    image: golang:1.25.0-alpine
    working_dir: /src
    environment:
      DATABASE_DSN: postgres://gophkeeper:gophkeeper@postgres:5432/gophkeeper?sslmode=disable
      GRPC_SERVER_ADDRESS: main:3200
    volumes:
      - .:/src
    ports:
      - "3200:3200"
    command: sh -c "go run app/server/main.go"
    depends_on:
      postgres:
        condition: service_healthy

volumes:
  postgres_data:
